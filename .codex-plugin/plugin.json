{
  "name": "shipkit",
  "version": "1.0.0",
  "description": "Code Development OS — 14 agents, 7 production-hardening skills, 6-phase pipeline for production-ready code",
  "repository": "github.com/Akakaui/shipkit",
  "homepage": "https://github.com/Akakaui/shipkit",
  "author": "Akakaui",
  "license": "MIT",
  "skills": [
    "production-hardening",
    "infra-networking",
    "container-orch",
    "db-scale",
    "resilience-patterns",
    "security-hardening",
    "prod-ops"
  ],
  "agents": [
    {
      "name": "code",
      "prompt": "agents/code/AGENT.md",
      "description": "Master orchestrator — routes requests to sub-agents"
    },
    {
      "name": "planner",
      "prompt": "agents/planner/AGENT.md",
      "description": "Requirements, scope, features (Phase 1)"
    },
    {
      "name": "architect",
      "prompt": "agents/architect/AGENT.md",
      "description": "Stack, data model, API design (Phase 2)"
    },
    {
      "name": "frontend",
      "prompt": "agents/frontend/AGENT.md",
      "description": "UI components, state management, user interfaces"
    },
    {
      "name": "backend",
      "prompt": "agents/backend/AGENT.md",
      "description": "APIs, databases, authentication, server logic"
    }
  ],
  "scaffold": {
    "templates": "templates/",
    "entry": "templates/project.json"
  },
  "install": {
    "method": "npm",
    "package": "@akakaui/shipkit"
  }
}
